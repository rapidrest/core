{
    "name": "@rapidrest/core",
    "version": "1.10.0",
    "description": "A collection of common utilities and core functionality for rapidly building RESTful applications.",
    "repository": "https://github.com/rapidrest/core.git",
    "author": "RapidREST <rapidrests@gmail.com>",
    "license": "MIT",
    "contributors": [
        "Jean-Philippe Steinmetz",
        "Arthur Thompson",
        "Thomas Buscaglia"
    ],
    "scripts": {
        "build": "yarn lint && rimraf dist && tsc",
        "lint": "eslint ./src ./test",
        "local-audit": "yarn install && yarn npm audit -A -R \"$@\"",
        "checkup": "yarn dlx @yarnpkg/doctor \"$@\"",
        "dependency-check": "yarn dlx depcheck \"$@\"",
        "report-coverage": "cat ./coverage/lcov.info | coveralls",
        "test": "node --loader ts-node/esm ./node_modules/vitest/vitest.mjs run --config test/vitest.config.ts --coverage",
        "test:prod": "npm run lint && node --loader ts-node/esm ./node_modules/vitest/vitest.mjs run --config test/vitest.config.ts --coverage",
        "postversion": "git push && git push --tags"
    },
    "dependencies": {
        "form-data": "^4.0.5",
        "handlebars": "^4.7.9",
        "js-yaml": "^4.2.0",
        "jsonwebtoken": "^9.0.3",
        "jszip": "^3.10.1",
        "mkdirp": "^3.0.1",
        "triple-beam": "^1.4.1",
        "uuid": "^14.0.0",
        "validator": "^13.15.35"
    },
    "peerDependencies": {
        "axios": "1.x",
        "reflect-metadata": "0.2.x",
        "winston": "3.x",
        "winston-transport": "4.x"
    },
    "devDependencies": {
        "@slack/bolt": "^4.7.3",
        "@slack/web-api": "^7.16.0",
        "@types/eslint": "^9.6.1",
        "@types/express": "^5.0.6",
        "@types/js-yaml": "^4.0.9",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/node": "^25.9.2",
        "@types/nodemailer": "^8.0.0",
        "@types/triple-beam": "^1.3.5",
        "@types/validator": "^13.15.10",
        "@typescript-eslint/eslint-plugin": "^8.61.0",
        "@typescript-eslint/parser": "^8.61.0",
        "@vitest/coverage-v8": "^4.1.10",
        "axios": "^1.17.0",
        "coveralls": "^3.1.1",
        "eslint": "^9.39.4",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-jsdoc": "^63.0.2",
        "mkdirp": "^3.0.1",
        "nconf": "^0.13.0",
        "nock": "^14.0.15",
        "nodemailer": "^8.0.10",
        "prettier": "^3.8.4",
        "reflect-metadata": "^0.2.2",
        "rimraf": "^6.1.3",
        "ts-node": "^10.9.2",
        "twilio": "^6.0.2",
        "typescript": "^6.0.3",
        "vitest": "^4.1.10",
        "winston": "^3.19.0",
        "winston-transport": "^4.9.0"
    },
    "resolutions": {
        "cross-spawn": "^7.0.5"
    },
    "packageManager": "yarn@4.5.0",
    "engines": {
        "node": ">=24.0.0"
    },
    "publishConfig": {
        "registry": "https://registry.npmjs.org/"
    },
    "main": "dist/lib/index.js",
    "type": "module",
    "typings": "dist/types/index.d.ts",
    "files": [
        "dist"
    ]
}
